# Local development API port.
PORT=4000

# Recommended for Vercel + Supabase.
# Use the Supabase Postgres connection string from Project Settings > Database.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres
DB_SSL=true
DB_SCHEMA=inventory_laptop

# Optional local Postgres settings if you are not using DATABASE_URL.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=inventory_laptop

# Leave blank on Vercel when the API is deployed in the same project.
# For local development, scripts/dev.js injects http://localhost:${PORT}.
VITE_API_URL=
